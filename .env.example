# =====================================================================
# AI Text Summarization — Environment Variables Template
# =====================================================================
# Copy this file to .env and fill in the values before running locally.
# NEVER commit your actual .env file to version control.
# =====================================================================

# Flask secret key (change this to a long random string in production)
SECRET_KEY=your-super-secret-key-here

# Set to "false" in production
FLASK_DEBUG=true

# Port to run the development server on
PORT=5000
